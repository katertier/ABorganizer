# ── Rust ────────────────────────────────────────────────────────────────
debug/
target/
**/*.rs.bk
*.pdb
**/mutants.out*/

# ── Swift ──────────────────────────────────────────────────────────────
**/.build/
**/DerivedData/
*.xcuserstate
*.xcuserdatad/
.swiftpm/
*.xcodeproj/xcuserdata/

# ── Frontend build (player UI) ──────────────────────────────────────────
crates/webui-player/frontend/node_modules/
crates/webui-player/frontend/dist/
crates/webui-player/frontend/.bun/
crates/webui-player/static/

# ── Local dev cruft ─────────────────────────────────────────────────────
/tmp/
*.log
.DS_Store
.cargo-ok
.envrc.local

# ── Editor / agent / IDE state ─────────────────────────────────────────
.idea/
.vscode/
.zed/
.claude/
MEMORY.md
*.local.md
*.scratch.md
*.draft.md

# ── Runtime data (should never be in repo) ──────────────────────────────
*.zst.tmp
*.db
*.db-wal
*.db-shm
*.db.zst

# ── Test fixtures (large, downloaded by scripts/build-fixtures.py) ──────
tests/fixtures/*.m4b
tests/fixtures/*.m4a
tests/fixtures/*.mp3
tests/fixtures/checksums.lock
!tests/fixtures/README.md
!tests/fixtures/manifest.toml

# ── Seed update artifacts ──────────────────────────────────────────────
crates/seed/data/cache/
